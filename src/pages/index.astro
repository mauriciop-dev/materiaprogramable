---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MateriaCanvas from '../components/MateriaCanvas.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categorias = {
    'fundamentos': { title: 'Átomos vs. Bits (Fundamentos)', desc: 'Educación y conceptos base de programación de la materia.' },
    'actualidad': { title: 'Frontera Tecnológica', desc: 'Resúmenes de avances, papers y noticias de laboratorios.' },
    'investigacion': { title: 'Investigación y Laboratorios', desc: 'Proyectos de investigación avanzada y laboratorios punteros.' },
    'casos-de-uso': { title: 'El Futuro Diseñado', desc: 'Casos inspiracionales de aplicación en industrias reales.' },
    'opinion': { title: 'Laboratorio de Ideas', desc: 'Debates éticos, impacto sociológico y filosofía de la materia inteligente.' }
};

const groupedPosts = {
    'fundamentos': posts.filter(post => post.data.category === 'fundamentos'),
    'actualidad': posts.filter(post => post.data.category === 'actualidad'),
    'investigacion': posts.filter(post => post.data.category === 'investigacion'),
    'casos-de-uso': posts.filter(post => post.data.category === 'casos-de-uso'),
    'opinion': posts.filter(post => post.data.category === 'opinion'),
};
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            .category-section {
                margin-top: 4rem;
            }
            .category-section h2 {
                color: var(--accent);
                border-bottom: 2px solid var(--glass-border);
                padding-bottom: 0.5rem;
                margin-bottom: 0.5rem;
                text-shadow: 0 0 10px rgba(0, 240, 255, 0.4);
            }
            .category-desc {
                color: rgb(var(--gray-light));
                opacity: 0.8;
                font-size: 0.9em;
                margin-bottom: 1.5rem;
                font-style: italic;
            }
            .post-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                gap: 1.5rem;
            }
            .post-card {
                padding: 1.5em;
                text-decoration: none !important;
                display: flex;
                flex-direction: column;
            }
            .post-card h4 {
                font-size: 1.4rem;
                margin-bottom: 0.5rem;
                color: #fff;
            }
            .post-card .date {
                font-size: 0.8rem;
                color: var(--accent);
                margin-bottom: 1rem;
            }
            .post-card p {
                font-size: 0.9rem;
                color: rgb(var(--gray-light));
                margin: 0;
            }
            .post-card img {
                margin-bottom: 1rem;
                aspect-ratio: 16/9;
                object-fit: cover;
            }
            .empty-state {
                padding: 2rem;
                text-align: center;
                border: 1px dashed var(--glass-border);
                border-radius: 8px;
                opacity: 0.6;
            }
        </style>
	</head>
	<body>
        <MateriaCanvas />
		<Header />
		<main>
			<section class="glass-panel" style="margin-bottom: 3rem; padding: 1rem; position: relative;">
                <div style="position: absolute; top: 0.5rem; left: 0; right: 0; text-align: center; z-index: 10;">
                    <p style="font-size: 1.1rem; font-style: italic; color: #00ffff; text-shadow: 0 0 10px rgba(0,240,255,0.5); margin: 0;">
                        "La materia programable es lograr que la materia cambie, se adopte o responda al entorno y contexto."
                    </p>
                </div>
                <div style="padding:42% 0 0 0;position:relative;margin-top: 2rem;border-radius: 8px;overflow: hidden;">
                    <iframe src="https://player.vimeo.com/video/298407221?badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" referrerpolicy="strict-origin-when-cross-origin" style="position:absolute;top:0;left:0;width:100%;height:100%;" title="Active Textile Tailoring"></iframe>
                </div>
            </section>

            {Object.entries(categorias).map(([key, info]) => (
                <section class="category-section">
                    <h2>{info.title}</h2>
                    <p class="category-desc">{info.desc}</p>
                    
                    {groupedPosts[key as keyof typeof groupedPosts].length > 0 ? (
                        <div class="post-grid">
                            {groupedPosts[key as keyof typeof groupedPosts].map((post) => (
                                <a href={`/blog/${post.id}/`} class="glass-panel post-card">
                                    {post.data.heroImage && <img src={post.data.heroImage} alt="" />}
                                    <h4>{post.data.title}</h4>
                                    <span class="date">
                                        <time datetime={post.data.pubDate.toISOString()}>
                                            {post.data.pubDate.toLocaleDateString('es-es', {
                                                year: 'numeric',
                                                month: 'short',
                                                day: 'numeric',
                                            })}
                                        </time>
                                    </span>
                                    <p>{post.data.description}</p>
                                </a>
                            ))}
                        </div>
                    ) : (
                        <div class="empty-state glass-panel" style="padding:1rem;">
                            <p style="margin:0; font-size:0.9rem;">Próximamente: Archivos en encriptación...</p>
                        </div>
                    )}
                </section>
            ))}
		</main>
		<Footer />
	</body>
</html>
