---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ArticleCanvas from '../components/ArticleCanvas.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, animation, ogImage } = Astro.props;
const currentUrl = Astro.url.href;
const fullTitle = `${title} | Materia Programable`;
---

<html lang={Astro.url.pathname.includes('/blog/en/') ? 'en' : 'es'}>
	<head>
		<BaseHead title={fullTitle} description={description} ogImage={ogImage} />
		<!-- SEO 2026 Meta Tags -->
		<meta name="year" content="2026" />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#00f0ff" />
		<!-- FontAwesome CDN -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
		<script define:vars={{ currentUrl, fullTitle, description }}>
			window.SHARE_DATA = {
				url: currentUrl,
				title: fullTitle,
				description: description
			};
		</script>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1.5rem;
				color: rgb(var(--gray-light));
				background: rgba(0, 0, 0, 0.3);
				border-radius: 12px;
				border: 1px solid var(--glass-border);
			}
			.prose img, .img-fluid {
				max-width: 100%;
				height: auto;
				border: 2px solid var(--neon-cyan, #00ffff);
				border-radius: 8px;
				box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray-light));
			}
			.last-updated-on {
				font-style: italic;
			}
			.interaction-bar {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.8rem;
				padding: 1.5rem;
				margin: 2rem 0;
				background: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(12px);
				border-radius: 12px;
				border: 1px solid rgba(0, 240, 255, 0.5);
				box-shadow: 0 0 10px rgba(0, 240, 255, 0.1);
				flex-wrap: wrap;
			}
			.interaction-btn {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.6rem 1rem;
				background: rgba(0, 240, 255, 0.1);
				border: 1px solid var(--accent);
				border-radius: 8px;
				color: var(--accent);
				font-size: 0.85rem;
				cursor: pointer;
				transition: all 0.3s ease;
				text-decoration: none;
			}
			.interaction-btn:hover {
				background: rgba(0, 240, 255, 0.2);
				transform: translateY(-2px);
				box-shadow: 0 0 15px rgba(0, 240, 255, 0.3);
			}
			.interaction-btn svg {
				width: 18px;
				height: 18px;
				flex-shrink: 0;
			}
			.like-btn.liked {
				background: rgba(255, 100, 100, 0.2);
				border-color: #ff6464;
				color: #ff6464;
			}
			.like-count {
				font-weight: bold;
				min-width: 20px;
				text-align: center;
			}
			.share-menu {
				position: relative;
			}
			.share-dropdown {
				display: none;
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%);
				margin-top: 0.5rem;
				background: rgba(0, 0, 0, 0.6);
				backdrop-filter: blur(12px);
				border: 1px solid rgba(167, 139, 250, 0.6);
				box-shadow: 0 0 15px rgba(167, 139, 250, 0.3);
				border-radius: 8px;
				padding: 0.5rem;
				z-index: 100;
			}
			.insight-dropdown {
				display: none;
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%);
				margin-top: 0.5rem;
				background: rgba(0, 0, 0, 0.6);
				backdrop-filter: blur(12px);
				border: 1px solid rgba(167, 139, 250, 0.6);
				box-shadow: 0 0 15px rgba(167, 139, 250, 0.3);
				border-radius: 8px;
				padding: 1rem;
				z-index: 100;
				width: 300px;
				max-width: 90vw;
			}
			.insight-dropdown.show { display: block; }
			.insight-dropdown ul { list-style: none; padding: 0; margin: 0; }
			.insight-dropdown li { margin-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem; }
			.insight-dropdown a { color: #a78bfa; text-decoration: none; font-size: 0.85rem; display: block; word-break: break-all; }
			.insight-dropdown a:hover { color: #fff; }
			
			.suggest-modal {
				display: none;
				position: fixed;
				top: 0; left: 0; width: 100%; height: 100%;
				background: rgba(0,0,0,0.5);
				backdrop-filter: blur(5px);
				z-index: 1000;
				align-items: center;
				justify-content: center;
			}
			.suggest-modal.show { display: flex; }
			.suggest-content {
				background: rgba(0, 0, 0, 0.8);
				backdrop-filter: blur(12px);
				border: 1px solid rgba(0, 240, 255, 0.6);
				box-shadow: 0 0 20px rgba(0, 240, 255, 0.3);
				padding: 2rem;
				border-radius: 12px;
				width: 400px;
				max-width: 90vw;
			}
			.suggest-content textarea {
				width: 100%; height: 100px;
				background: rgba(0,0,0,0.5); border: 1px solid var(--glass-border);
				color: white; padding: 0.5rem; border-radius: 6px; margin-bottom: 1rem;
			}
			.suggest-content button {
				background: var(--accent); color: black; border: none; padding: 0.5rem 1rem;
				border-radius: 6px; cursor: pointer; font-weight: bold; width: 100%;
			}
			.suggest-close {
				float: right; cursor: pointer; color: white; font-size: 1.5rem;
			}
			.share-dropdown.show {
				display: flex;
				flex-direction: column;
				gap: 0.3rem;
			}
			.share-option {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.5rem 0.8rem;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.8rem;
				transition: background 0.2s;
			}
			.share-option:hover {
				background: rgba(0, 240, 255, 0.1);
			}
			.share-option.facebook { color: #1877f2; }
			.share-option.whatsapp { color: #25d366; }
			.share-option.linkedin { color: #0a66c2; }
			.share-option i {
				width: 16px;
				text-align: center;
			}
			.suggestion-form {
				display: none;
				margin-top: 1rem;
				padding: 1rem;
				background: rgba(0, 0, 0, 0.5);
				border-radius: 8px;
			}
			.suggestion-form.show {
				display: block;
			}
			.suggestion-form textarea {
				width: 100%;
				padding: 0.8rem;
				border-radius: 8px;
				border: 1px solid var(--glass-border);
				background: rgba(0, 0, 0, 0.5);
				color: #fff;
				font-size: 0.9rem;
				resize: vertical;
				min-height: 100px;
				box-sizing: border-box;
			}
			.suggestion-form textarea:focus {
				outline: none;
				border-color: var(--accent);
			}
			.suggestion-form button {
				margin-top: 0.8rem;
				padding: 0.6rem 1.2rem;
				background: var(--accent);
				border: none;
				border-radius: 6px;
				color: #000;
				font-weight: bold;
				cursor: pointer;
				transition: transform 0.2s;
			}
			.suggestion-form button:hover {
				transform: translateY(-2px);
			}
			.success-msg {
				display: none;
				color: #00ff00;
				margin-top: 0.5rem;
				text-align: center;
			}
			.success-msg.show {
				display: block;
			}
			.insight-btn {
				background: rgba(167, 139, 250, 0.1);
				border-color: #a78bfa;
				color: #a78bfa;
			}
			.insight-btn:hover {
				background: rgba(167, 139, 250, 0.2);
				box-shadow: 0 0 15px rgba(167, 139, 250, 0.3);
			}
			.chat-section {
				margin: 2rem 0;
				padding: 1.5rem;
				background: rgba(0, 0, 0, 0.4);
				border-radius: 12px;
				border: 1px solid var(--glass-border);
			}
			.chat-section h3 {
				color: var(--accent);
				margin: 0 0 1rem 0;
				text-align: center;
			}
			.chat-input-container {
				display: flex;
				gap: 0.5rem;
			}
			.chat-input {
				flex: 1;
				padding: 0.8rem;
				border-radius: 8px;
				border: 1px solid var(--glass-border);
				background: rgba(0, 0, 0, 0.5);
				color: #fff;
				font-size: 0.9rem;
			}
			.chat-input:focus {
				outline: none;
				border-color: var(--accent);
			}
			.chat-send-btn {
				padding: 0.8rem 1.2rem;
				background: linear-gradient(135deg, var(--accent), #8b5cf6);
				border: none;
				border-radius: 8px;
				color: #fff;
				font-weight: bold;
				cursor: pointer;
				transition: transform 0.2s;
			}
			.chat-send-btn:hover {
				transform: translateY(-2px);
			}
			.chat-response {
				margin-top: 1rem;
				padding: 1rem;
				background: rgba(0, 0, 0, 0.3);
				border-radius: 8px;
				border-left: 3px solid var(--accent);
				display: none;
			}
			.chat-response.show {
				display: block;
			}
			.community-form {
				margin: 2rem 0;
				padding: 1.5rem;
				background: rgba(0, 0, 0, 0.4);
				border-radius: 12px;
				border: 1px solid var(--glass-border);
			}
			.community-form h3 {
				color: var(--accent);
				margin: 0 0 0.5rem 0;
				text-align: center;
			}
			.community-form p {
				color: rgb(var(--gray-light));
				text-align: center;
				font-size: 0.9rem;
				margin-bottom: 1rem;
			}
			.community-form input {
				width: 100%;
				padding: 0.8rem;
				border-radius: 8px;
				border: 1px solid var(--glass-border);
				background: rgba(0, 0, 0, 0.5);
				color: #fff;
				font-size: 0.9rem;
				margin-bottom: 0.8rem;
				box-sizing: border-box;
			}
			.community-form input:focus {
				outline: none;
				border-color: var(--accent);
			}
			.community-form button {
				width: 100%;
				padding: 0.8rem;
				background: linear-gradient(135deg, #00ffff, #8b5cf6);
				border: none;
				border-radius: 8px;
				color: #000;
				font-weight: bold;
				font-size: 1rem;
				cursor: pointer;
				transition: transform 0.2s;
			}
			.community-form button:hover {
				transform: translateY(-2px);
				box-shadow: 0 0 20px rgba(0, 240, 255, 0.4);
			}
			.community-success {
				display: none;
				color: #00ff00;
				text-align: center;
				margin-top: 1rem;
			}
			.community-success.show {
				display: block;
			}
		</style>
	</head>

	<body>
		{animation && <ArticleCanvas theme={animation.theme} primaryColor={animation.primaryColor} secondaryColor={animation.secondaryColor} particleCount={animation.particleCount} shape={animation.shape} movement={animation.movement} speed={animation.speed} interaction={animation.interaction} cameraMode={animation.cameraMode} specialEffects={animation.specialEffects} />}
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					
					<div class="interaction-bar">
						<button class="interaction-btn like-btn" id="likeBtn">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
							<span class="like-count" id="likeCount">0</span>
							<span id="likeText">Me gusta</span>
						</button>
						
						<div class="share-menu">
							<button class="interaction-btn" id="shareBtn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
								<span>Compartir</span>
							</button>
							<div class="share-dropdown" id="shareDropdown">
								<a href="#" class="share-option" id="shareX" style="color: #fff;">
									<i class="fa-brands fa-x-twitter"></i>
									X (Twitter)
								</a>
								<a href="#" class="share-option whatsapp" id="shareWhatsapp">
									<i class="fa-brands fa-whatsapp"></i>
									WhatsApp
								</a>
								<a href="#" class="share-option linkedin" id="shareLinkedin">
									<i class="fa-brands fa-linkedin"></i>
									LinkedIn
								</a>
							</div>
						</div>
						
						<div style="position: relative;">
							<button class="interaction-btn insight-btn" id="insightBtn">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
								<span>Insight</span>
							</button>
							<div class="insight-dropdown" id="insightDropdown">
								<h4 style="margin-top:0; color: #a78bfa;">Fuentes del Artículo</h4>
								<ul id="insightLinks"><li>Buscando fuentes...</li></ul>
							</div>
						</div>
						
						<button class="interaction-btn" id="suggestBtn">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
							<span>Sugerir</span>
						</button>
						
						<div class="suggest-modal" id="suggestModal">
							<div class="suggest-content">
								<span class="suggest-close" id="suggestClose">&times;</span>
								<h3 style="color: #00ffcc; margin-top: 0;">Enviar Sugerencia</h3>
								<textarea id="suggestText" placeholder="¿Qué podríamos mejorar o agregar a este tema?"></textarea>
								<button id="suggestSubmitBtn">Enviar al Laboratorio</button>
								<p id="suggestStatus" style="display:none; color:#00ffcc; margin-top:0.5rem; text-align:center;"></p>
							</div>
						</div>
					</div>

					<div class="chat-section" id="chat-article-container">
						<h3>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;vertical-align:middle;margin-right:8px;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
							Pregúntale al Artículo
						</h3>
						<p style="font-size: 0.85rem; opacity: 0.7; margin-bottom: 1rem;">Pregunta sobre el contenido y la IA te responderá usando solo este artículo como contexto.</p>
						<div class="chat-input-container">
							<input type="text" class="chat-input" id="chatInput" placeholder="¿De qué trata este artículo?" />
							<button class="chat-send-btn" id="chatSend">Enviar</button>
						</div>
						<div class="chat-response" id="chatResponse"></div>
					</div>

					<form action="https://formspree.io/f/mzdyzqwb" method="POST" class="community-form" id="communityForm">
						<h3>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;vertical-align:middle;margin-right:8px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
							Unirse a la Red de Investigación
						</h3>
						<p>Acceso a papers exclusivos, networking con expertos y actualizaciones de vanguardia en Latinoamérica.</p>
						<input type="text" name="name" placeholder="Tu nombre" required />
						<input type="email" name="email" placeholder="Tu correo electrónico" required />
						<input type="text" name="affiliation" placeholder="Universidad o empresa (opcional)" />
						<button type="submit" id="communitySubmitBtn">Unirse a la Red de Investigación</button>
						<div class="community-success" id="communitySuccess">✅ ¡Bienvenido a la comunidad! Te contactaremos pronto.</div>
					</form>
				</div>
			</article>
		</main>
		<Footer />

		<script>
			const likeBtn = document.getElementById('likeBtn');
			const likeCount = document.getElementById('likeCount');
			const likeText = document.getElementById('likeText');
			let liked = false;
			let likeCounter = Math.floor(Math.random() * 50) + 10;
			
			if (likeCount) likeCount.textContent = likeCounter.toString();
			
			if (likeBtn) {
				likeBtn.addEventListener('click', () => {
					liked = !liked;
					if (liked) {
						likeCounter++;
						if (likeText) likeText.textContent = 'Te gusta';
					} else {
						likeCounter--;
						if (likeText) likeText.textContent = 'Me gusta';
					}
					if (likeCount) likeCount.textContent = likeCounter.toString();
					likeBtn.classList.toggle('liked');
				});
			}

			const shareBtn = document.getElementById('shareBtn');
			const shareDropdown = document.getElementById('shareDropdown');
			const shareData = window.SHARE_DATA || { url: window.location.href, title: document.title, description: '' };

			if (shareBtn && shareDropdown) {
				shareBtn.addEventListener('click', (e) => {
					e.preventDefault();
					shareDropdown.classList.toggle('show');
				});

				document.addEventListener('click', (e) => {
					if (!shareBtn.contains(e.target) && !shareDropdown.contains(e.target)) {
						shareDropdown.classList.remove('show');
					}
				});
			}

			// Meta-Tag og:image for Share
			const ogImageMeta = document.querySelector('meta[property="og:image"]');
			let ogImageUrl = ogImageMeta ? ogImageMeta.content : '';
			if(ogImageUrl && !ogImageUrl.startsWith('http')) {
				ogImageUrl = new URL(ogImageUrl, window.location.origin).href;
			}
			shareData.url = ogImageUrl ? shareData.url + '?img=' + encodeURIComponent(ogImageUrl) : shareData.url;

			const shareX = document.getElementById('shareX');
			const shareWhatsapp = document.getElementById('shareWhatsapp');
			const shareLinkedin = document.getElementById('shareLinkedin');

			if (shareX) {
				shareX.href = `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareData.url)}&text=${encodeURIComponent(shareData.title)}`;
			}
			if (shareWhatsapp) {
				shareWhatsapp.href = `https://wa.me/?text=${encodeURIComponent(shareData.title + ' - ' + shareData.url)}`;
			}
			if (shareLinkedin) {
				shareLinkedin.href = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(shareData.url)}&title=${encodeURIComponent(shareData.title)}&summary=${encodeURIComponent(shareData.description)}`;
			}

			// Suggest Logic (Supabase via REST)
			const suggestBtn = document.getElementById('suggestBtn');
			const suggestModal = document.getElementById('suggestModal');
			const suggestClose = document.getElementById('suggestClose');
			const suggestSubmitBtn = document.getElementById('suggestSubmitBtn');
			const suggestText = document.getElementById('suggestText');
			const suggestStatus = document.getElementById('suggestStatus');

			if(suggestBtn) {
				suggestBtn.addEventListener('click', () => suggestModal.classList.add('show'));
				suggestClose.addEventListener('click', () => suggestModal.classList.remove('show'));
				suggestSubmitBtn.addEventListener('click', async () => {
					const msg = suggestText.value.trim();
					if(!msg) return;
					
					suggestSubmitBtn.textContent = 'Enviando...';
					suggestSubmitBtn.disabled = true;
					
					try {
						// Fallback url if env not ready yet
						const supaUrl = import.meta.env ? import.meta.env.PUBLIC_SUPABASE_URL : '';
						const supaKey = import.meta.env ? import.meta.env.PUBLIC_SUPABASE_ANON_KEY : '';
						
						if(supaUrl && supaKey) {
							await fetch(`${supaUrl}/rest/v1/suggestions`, {
								method: 'POST',
								headers: {
									'Content-Type': 'application/json',
									'apikey': supaKey,
									'Authorization': `Bearer ${supaKey}`
								},
								body: JSON.stringify({ message: msg, article_url: window.location.href })
							});
						} else {
							await new Promise(r => setTimeout(r, 1000));
							console.log('Simulated Supabase Insert:', msg);
						}
						
						suggestStatus.textContent = '¡Sugerencia recibida en el laboratorio!';
						suggestStatus.style.display = 'block';
						suggestText.value = '';
						setTimeout(() => {
							suggestModal.classList.remove('show');
							suggestStatus.style.display = 'none';
							suggestSubmitBtn.textContent = 'Enviar al Laboratorio';
							suggestSubmitBtn.disabled = false;
						}, 3000);
					} catch(e) {
						suggestSubmitBtn.textContent = 'Error';
						setTimeout(() => { suggestSubmitBtn.textContent = 'Enviar al Laboratorio'; suggestSubmitBtn.disabled = false; }, 2000);
					}
				});
			}

			// Community Form
			const communityForm = document.getElementById('communityForm');
			const communitySubmitBtn = document.getElementById('communitySubmitBtn');
			const communitySuccess = document.getElementById('communitySuccess');

			if (communityForm) {
				communityForm.addEventListener('submit', async (e) => {
					e.preventDefault();
					const formData = new FormData(communityForm);
					if(communitySubmitBtn) {
						communitySubmitBtn.textContent = 'Procesando...';
						communitySubmitBtn.disabled = true;
					}
					try {
						const response = await fetch(communityForm.action, {
							method: 'POST',
							body: formData,
							headers: { 'Accept': 'application/json' }
						});
						if (response.ok) {
							communityForm.reset();
							communitySuccess.classList.add('show');
							if(communitySubmitBtn) {
								communitySubmitBtn.textContent = 'Unirse a la Red de Investigación';
								communitySubmitBtn.disabled = false;
							}
							setTimeout(() => communitySuccess.classList.remove('show'), 5000);
						}
					} catch (err) {
						console.error('Error:', err);
						if(communitySubmitBtn) {
							communitySubmitBtn.textContent = 'Error al unirse';
							setTimeout(() => { communitySubmitBtn.textContent = 'Unirse a la Red de Investigación'; communitySubmitBtn.disabled = false; }, 3000);
						}
					}
				});
			}

			// Insight Logic
			const insightBtn = document.getElementById('insightBtn');
			const insightDropdown = document.getElementById('insightDropdown');
			const insightLinks = document.getElementById('insightLinks');
			if (insightBtn && insightDropdown) {
				insightBtn.addEventListener('click', () => {
					insightDropdown.classList.toggle('show');
					// Extract links if not done yet
					if(insightLinks.children[0] && insightLinks.children[0].textContent === 'Buscando fuentes...') {
						const links = Array.from(document.querySelectorAll('.reference-link'));
						if(links.length > 0) {
							insightLinks.innerHTML = links.map(l => {
								let metaData = '';
								if(l.href.includes('s41567-026-03226-2')) metaData = '<br><span style="font-size:0.75rem; color:#8b5cf6;">Nature Physics (2026) - Autonomous microrobots</span>';
								if(l.href.includes('adp7821')) metaData = '<br><span style="font-size:0.75rem; color:#8b5cf6;">Science Robotics (2026) - Microelectronic circuits</span>';
								return `<li style="padding: 0.5rem; background: rgba(255,255,255,0.05); border-radius: 4px; margin-bottom: 0.5rem;"><a href="${l.href}" target="_blank" style="font-weight:bold;">${l.textContent || l.href}</a>${metaData}</li>`;
							}).join('');
						} else {
							insightLinks.innerHTML = '<li>No se detectaron referencias (clase .reference-link).</li>';
						}
					}
				});
				document.addEventListener('click', (e) => {
					if (!insightBtn.contains(e.target) && !insightDropdown.contains(e.target)) {
						insightDropdown.classList.remove('show');
					}
				});
			}

			const chatInput = document.getElementById('chatInput');
			const chatSend = document.getElementById('chatSend');
			const chatResponse = document.getElementById('chatResponse');

			function getArticleContent() {
				const articleElement = document.querySelector('.prose');
				if (articleElement) {
					return articleElement.innerText;
				}
				return '';
			}

			function generateResponse(question, content) {
				const q = question.toLowerCase();
				const sentences = content.split(/[.!?]+/).filter(s => s.trim().length > 20);
				
				const questionPatterns = {
					'diferencia': () => {
						const robotKeywords = ['robotica tradicional', 'un solo robot', 'una tarea'];
						const mpKeywords = ['materia programable', 'enjambre', 'sistemas distribuidos', 'cooperacion masiva', 'unidades minimas'];
						
						const robotSentences = sentences.filter(s => 
							robotKeywords.some(k => s.toLowerCase().includes(k))
						);
						const mpSentences = sentences.filter(s => 
							mpKeywords.some(k => s.toLowerCase().includes(k))
						);
						
						if (robotSentences.length > 0 && mpSentences.length > 0) {
							return `La principal diferencia es que la <strong>robótica tradicional</strong> consiste en robots individuales que cumplen una tarea específica, mientras que la <strong>materia programable</strong> se basa en inteligencia de enjambre y sistemas distribuidos donde miles de unidades mínimas trabajan cooperando para crear objetos emergentes. ${mpSentences[0]}`;
						}
						return sentences[0] || '';
					},
					'que es': () => {
						const match = content.match(/materia programable[^.]+/i);
						return match ? match[0].substring(0, 300) + '.' : sentences[0];
					},
					'resumen': () => {
						return sentences.slice(0, 2).join('. ') + '.';
					}
				};

				for (const [pattern, handler] of Object.entries(questionPatterns)) {
					if (q.includes(pattern)) {
						const response = handler(content);
						if (response) return response;
					}
				}

				const randomSentences = sentences.sort(() => 0.5 - Math.random()).slice(0, 2);
				if (randomSentences.length > 0) {
					return randomSentences.join('. ') + '.';
				}
				
				return `Este artículo trata sobre materia programable. ${sentences[0] || 'Puedes leer el contenido completo arriba para más detalles.'}`;
			}

			if (chatSend && chatInput && chatResponse) {
				chatSend.addEventListener('click', async () => {
					const question = chatInput.value.trim();
					if (!question) return;

					chatResponse.innerHTML = '🤖 Analizando el artículo...';
					chatResponse.classList.add('show');

					await new Promise(resolve => setTimeout(resolve, 800));

					const articleContent = getArticleContent();
					const response = generateResponse(question, articleContent);

					chatResponse.innerHTML = `<strong>Respuesta basada en este artículo:</strong><br><br>${response}`;
				});

				chatInput.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') {
						chatSend.click();
					}
				});
			}
		</script>
	</body>
</html>